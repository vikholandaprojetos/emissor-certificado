{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/i/(.*)", "destination": "/api/index.js" },
    { "source": "/healthz", "destination": "/api/index.js" }
  ]
}
