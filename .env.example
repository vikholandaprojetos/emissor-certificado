# ============================================================
#  VARIAVEIS DE AMBIENTE
#  - Na VERCEL: defina em Project > Settings > Environment Variables
#  - LOCALMENTE: copie este arquivo para ".env" e preencha
# ============================================================

# ---------- OBRIGATORIO EM PRODUCAO ----------

# Senha do painel /admin e /api (Edge Middleware).
# Deixe VAZIO = sem senha (so recomendado em teste local).
ADMIN_USER=
ADMIN_PASS=

# Storage dos templates e dos fundos (Vercel Blob).
# Na Vercel: criada SOZINHA ao conectar um Blob Store (aba Storage).
# Localmente: cole aqui o token do Blob Store para rodar "npm start".
BLOB_READ_WRITE_TOKEN=

# ---------- OPCIONAL ----------

# Resolucao da imagem (2 = retina/nitido). Padrao: 2
DEVICE_SCALE=2

# ---------- SO PARA RODAR LOCALMENTE (fora da Vercel) ----------

# Porta do servidor local. Padrao: 3000
PORT=3000

# Caminho de um Chrome/Chromium instalado, usado para renderizar localmente.
# Na Vercel isso NAO e necessario (usa o @sparticuz/chromium).
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
